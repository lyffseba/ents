# .env.example - copy to .env (gitignored) or set in Cloud Run secrets
DEBUG=true
SECRET_KEY=change-me
DATABASE_URL=sqlite:///./web/ents_academy.db

# REQUIRED for Gemini (XPRIZE rule: at least one LLM call in deployed app)
GEMINI_API_KEY=your-google-gemini-key-here
# Or for stronger Google Cloud: USE_VERTEX=true + ADC / service account

# Stripe (live keys for real revenue in contest window)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PRO_PRICE_ID=price_...

# Optional GC
GCP_PROJECT=your-project
